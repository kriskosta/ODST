					<h1 class="pagetitle"><span class="mw-page-title-main">Main Page</span></h1>					<p class='subtitle'>From Halopedia, the Halo wiki</p>
					<div id="contentSub"></div>
															<!-- start content -->
					<div id="mw-content-text" class="mw-body-content mw-content-ltr" lang="en" dir="ltr"><div id="adBanner" class="adWrapper" style="margin:0 0 12.5px"><!-- Tag ID: halopedia_leaderboard_atf -->
